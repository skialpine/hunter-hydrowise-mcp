{
  "name": "hydrowise-mcp",
  "version": "0.2.0",
  "description": "MCP server for the Hunter HydroWise (Hydrawise) cloud irrigation platform.",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "hydrowise-mcp": "dist/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/server.ts",
