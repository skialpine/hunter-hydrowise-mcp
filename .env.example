# Required: Hydrawise account credentials.
HYDRAWISE_USERNAME=
HYDRAWISE_PASSWORD=

# Optional: HTTP server bind. Default 127.0.0.1:8765.
# Non-loopback hosts require HYDRAWISE_MCP_AUTH_TOKEN.
HYDRAWISE_MCP_HOST=127.0.0.1
HYDRAWISE_MCP_PORT=8765

# Optional: comma-separated allowlist for the Origin header.
# Defaults to any loopback origin (http://127.0.0.1[:port], http://localhost[:port], http://[::1][:port]).
# HYDRAWISE_MCP_ALLOWED_ORIGINS=http://localhost:8765,http://127.0.0.1:8765

# Optional: when set, every /mcp request must carry "Authorization: Bearer <token>".
# HYDRAWISE_MCP_AUTH_TOKEN=

# Optional: idle session timeout in seconds (default 3600).
HYDRAWISE_MCP_SESSION_TTL=3600

# Optional: error | warn | info | debug. Default warn.
HYDRAWISE_LOG_LEVEL=warn
